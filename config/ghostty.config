# -*- mode: conf-space -*-

# ghostty +help
# ghostty +version
# ghostty +list-fonts
# ghostty +list-keybinds --docs --default
# ghostty +list-themes
# ghostty +list-colors
# ghostty +list-actions --docs
# ghostty +show-config
# ghostty +validate-config
# ghostty +show-face
# ghostty +crash-report

# command = /opt/homebrew/bin/fish

theme = dark:Arthur,light:Dawnfox
background-opacity = 1
# font-size = 14
unfocused-split-opacity = 0.6

# behavior settings
quit-after-last-window-closed = true
scrollback-limit = 1073741824
window-save-state = always
copy-on-select = clipboard
clipboard-paste-protection = false

# window look & feel
window-theme = dark
window-decoration = auto
window-height = 45
window-width = 120
window-padding-x = 2,4
window-padding-y = 2,4
window-padding-balance = true
window-padding-color = background
quick-terminal-position = top
quick-terminal-size = 60%,60%

# cursor settings
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true

# disable ligatures
font-feature = -calt
font-feature = -liga
font-feature = -dlig

## Quick Terminal Prompt
keybind = global:cmd+shift+1=toggle_quick_terminal

## Cycle to next split (like emacs other-window)
keybind = super+alt+o=goto_split:next

## Auto-split (splits along the larger dimension)
keybind = super+shift+n=new_split:auto

## Command Prompt
keybind = super+shift+;=toggle_command_palette

## Jump to next/previous prompt
keybind = super+alt+p=jump_to_prompt:-1
keybind = super+alt+n=jump_to_prompt:1 

## Save entire output to file
keybind = super+s>s>y=write_screen_file:copy
keybind = super+s>s>p=write_screen_file:paste
keybind = super+s>s>o=write_screen_file:open

## Saving only scrollback output to file
keybind = super+s>a>y=write_scrollback_file:copy
keybind = super+s>a>p=write_scrollback_file:paste
keybind = super+s>a>o=write_scrollback_file:open

## Save only selection to file
keybind = super+s>r>y=write_selection_file:copy
keybind = super+s>r>p=write_selection_file:paste
keybind = super+s>r>o=write_selection_file:open


