# -*- mode: conf-space -*-

# ghostty +help
# +version
# +help
# +list-fonts
# +list-keybinds --docs --default
# +list-themes
# +list-colors
# +list-actions --docs
# +show-config
# +validate-config
# +show-face
# +crash-report

theme = Desert
background-opacity = 1
font-size = 13
unfocused-split-opacity = 0.6

# behavior settings
quit-after-last-window-closed = true
scrollback-limit = 1073741824
window-save-state = always
copy-on-select = clipboard
clipboard-paste-protection = false

# window look & feel
window-theme = dark
window-decoration = auto
window-height = 45
window-width = 120
window-padding-x = 2,4
window-padding-y = 2,4
window-padding-balance = true
window-padding-color = background

# cursor settings
cursor-style = block
cursor-style-blink = true
mouse-hide-while-typing = true

# disable ligatures
font-feature = -calt
font-feature = -liga
font-feature = -dlig


# Global Keybindings

## Quick Terminal Prompt
keybind = global:cmd+shift+1=toggle_quick_terminal

## Toggle all Ghostty windows visibility
keybind = global:cmd+shift+o=toggle_visibility


# Keybindings

## Reset
keybind = super+shift+r=reset

## Auto-split (splits along the larger dimension)
keybind = super+shift+n=new_split:auto

## Copy URL under cursor
keybind = super+shift+u=copy_url_to_clipboard

## Command Prompt
keybind = super+shift+;=toggle_command_palette

## Jump to next/previous prompt
keybind = super+alt+p=jump_to_prompt:-1
keybind = super+alt+n=jump_to_prompt:1 

## Search
keybind = super+shift+f=search_selection

## Saving Screen output
keybind = super+s>a>y=write_scrollback_file:copy
keybind = super+s>a>p=write_scrollback_file:paste
keybind = super+s>a>o=write_scrollback_file:open

keybind = super+s>s>y=write_screen_file:copy
keybind = super+s>s>p=write_screen_file:paste
keybind = super+s>s>o=write_screen_file:open

keybind = super+s>r>y=write_selection_file:copy
keybind = super+s>r>p=write_selection_file:paste
keybind = super+s>r>o=write_selection_file:open


