# -*- mode: conf-unix -*-

# Run on large repos that need to be maintained.
# git maintenance start

# To see which repos are resistered with maintenance.
# git config --global --get-all maintenance.repo

[alias]
    cm = commit -m
    co = checkout
    d = diff
    dv = difftool -t vimdiff -y
    f = fetch
    gl = config --global -l
    l = log -1 HEAD --stat
    ll = log --oneline
    rv = remote -v
    se = !git rev-list --all | xargs git grep -F
    st = status -sb

[branch]
    sort = -committerdate

[column]
    ui = auto

[core]
    autocrlf = input

[diff]
    algorithm = histogram
    colorMoved = plain

[fetch]
    prune = true

[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f

[init]
    defaultBranch = main

[merge]
    ff = only

[pull]
    rebase = true

[rebase]
    autoStash = true

[push]
    default = current
    autoSetupRemote = true

[rerere]
    enabled = true

[submodule]
    recurse = true

[tag]
    sort = version:refname

